{
  "name": "@petrher/sp-components",
  "version": "0.1.8",
  "description": "Custom reusable components and layouts built with Fluent UI React",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/PetrHer/sp-components.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.73.1",
    "react": ">=17.0.0 <18.0.0",
    "react-dom": ">=17.0.0 <18.0.0"
  },
  "devDependencies": {
    "@fluentui/react-components": "^9.73.1",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
